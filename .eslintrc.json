{
  "env": {
    "commonjs": true,
    "es2021": true,
    "node": true,
    "jest": true
  },
  "extends": ["airbnb-base"],
  "parserOptions": {
    "ecmaVersion": 12
  },
  "rules": {
    "no-console": "off",
    "class-methods-use-this": "off",
    "no-param-reassign": "off",
    "camelcase": "off",
    "consistent-return": "off",
    "max-len": ["error", { "code": 110 }],
    "eol-last": ["error", "always"]
  },
  "overrides": [
    {
      "files": ["**/__tests__/**/*.js"],
      "rules": {
        "max-len": ["warn", { "code": 140 }]
      }
    },
    {
      "files": ["src/database/migrations/**/*.js"],
      "rules": {
        "strict": "off",
        "arrow-body-style": "off",
        "no-unused-vars": "off",
        "comma-dangle": "off"
      }
    }
  ]
}